---
import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';
import Image from '~/components/common/Image.astro';
import { findImage } from '~/utils/images';
import { getPermalink } from '~/utils/permalinks';

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const image = await findImage(post.image);
const link = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';

const dateLabel = post.publishDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article
  class="mb-14 md:mb-20 rounded-lg overflow-hidden border border-gray-100 dark:border-slate-800 shadow-sm hover:shadow-md transition bg-white dark:bg-slate-900"
>
  <div class="grid md:grid-cols-2">
    <div class="relative md:aspect-auto aspect-[16/9] bg-gray-200 dark:bg-slate-800">
      {
        image &&
          (link ? (
            <a href={link} class="block h-full">
              <Image
                src={image}
                class="w-full h-full object-cover"
                widths={[640, 1280]}
                width={1280}
                sizes="(max-width: 768px) 100vw, 640px"
                alt={post.title}
                aspectRatio="16:9"
                layout="cover"
                loading="eager"
                decoding="async"
              />
            </a>
          ) : (
            <Image
              src={image}
              class="w-full h-full object-cover"
              widths={[640, 1280]}
              width={1280}
              sizes="(max-width: 768px) 100vw, 640px"
              alt={post.title}
              aspectRatio="16:9"
              layout="cover"
              loading="eager"
              decoding="async"
            />
          ))
      }
    </div>
    <div class="p-6 sm:p-8 md:p-10 flex flex-col justify-center">
      <div class="flex items-center gap-3 mb-3 text-sm">
        <span
          class="inline-flex items-center px-3 h-7 rounded-full bg-primary/10 text-primary font-medium uppercase tracking-wide text-xs"
        >
          Featured
        </span>
        {
          post.category && (
            <a
              href={getPermalink(post.category.slug, 'category')}
              class="text-muted hover:text-primary dark:text-slate-400"
            >
              {post.category.title}
            </a>
          )
        }
        {dateLabel && <span class="text-muted dark:text-slate-500">· {dateLabel}</span>}
      </div>
      <h2 class="font-heading text-2xl sm:text-3xl md:text-4xl font-bold leading-tight mb-3 dark:text-slate-200">
        {
          link ? (
            <a class="hover:text-primary transition" href={link}>
              {post.title}
            </a>
          ) : (
            post.title
          )
        }
      </h2>
      <p class="text-muted dark:text-slate-400 text-lg leading-relaxed mb-5">{post.excerpt}</p>
      {
        link && (
          <a
            href={link}
            class="inline-flex items-center self-start font-semibold text-primary hover:underline"
          >
            Read post <span class="ml-1">→</span>
          </a>
        )
      }
    </div>
  </div>
</article>
